# ===================================================
# FILE CẤU HÌNH MẪU (.env.example)
# ===================================================
# HƯỚNG DẪN:
#   1. Copy file này thành file .env  →  cp .env.example .env
#   2. Điền thông tin thực tế vào file .env
#   3. KHÔNG bao giờ commit file .env lên GitHub!
# ===================================================

# TOKEN của Telegram Bot (lấy từ @BotFather trên Telegram)
# Ví dụ: 1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
BOT_TOKEN=your_bot_token_here

# Danh sách Telegram User ID có quyền admin (cách nhau bởi dấu phẩy)
# Cách lấy User ID: nhắn tin cho @userinfobot trên Telegram
# Ví dụ: ADMIN_IDS=123456789,987654321
ADMIN_IDS=your_telegram_user_id_here
